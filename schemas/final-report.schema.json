{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/evidence-gated-multi-agent-operations/schemas/final-report.schema.json",
  "title": "Final Report",
  "type": "object",
  "required": ["summary", "verified", "changed_or_executed", "outputs", "remaining_risks", "next_actions_if_needed"],
  "additionalProperties": false,
  "properties": {
    "summary": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "verified": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["evidence", "result"],
        "additionalProperties": false,
        "properties": {
          "evidence": {"type": "string", "minLength": 1},
          "result": {"type": "string", "minLength": 1}
        }
      }
    },
    "changed_or_executed": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "outputs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path_or_url", "owner", "retention", "retrieval"],
        "additionalProperties": false,
        "properties": {
          "path_or_url": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "retention": {"type": "string", "minLength": 1},
          "retrieval": {"type": "string", "minLength": 1}
        }
      }
    },
    "remaining_risks": {"type": "array", "items": {"type": "string", "minLength": 1}},
    "next_actions_if_needed": {"type": "array", "items": {"type": "string", "minLength": 1}}
  }
}
